#include <Adafruit_GFX.h>
#include <MCUFRIEND_kbv.h>
#include <TouchScreen.h>
#include <EEPROM.h>

MCUFRIEND_kbv tft;

// TouchScreen pins for Velleman VMA412 / standard ILI9341 shields
#define YP A3  
#define XM A2  
#define YM 9   
#define XP 8   

// Standard Touch Calibration for VMA412 / MCUFriend ILI9341
#define TS_LEFT 150
#define TS_RT   920
#define TS_TOP  120
#define TS_BOT  940
#define MINPRESSURE 20
#define MAXPRESSURE 1000

TouchScreen ts = TouchScreen(XP, YP, XM, YM, 300);

// Colors (16-bit RGB565)
#define COLOR_OBSIDIAN    0x08A1
#define COLOR_NEON_CYAN   0x07FF
#define COLOR_NEON_MAG    0xF81F
#define COLOR_NEON_ORG    0xFC00
#define COLOR_NEON_GRN    0x07E0
#define COLOR_GLOW_CYAN   0x028A
#define COLOR_GLOW_MAG    0x5010
#define COLOR_GLASS_PANEL 0x1924
#define COLOR_BG          0x0000

// Pages
int currentPage = 1;
int lastPage = 0;
unsigned long lastUpdate = 0;
unsigned long lastTouch = 0;
bool screenSleeping = false;

// Config
bool graphMode = true;
int refreshRate = 2000; // ms

void calibrateDisplay() {
    tft.fillScreen(COLOR_OBSIDIAN);
    tft.setTextColor(0xFFFF); tft.setTextSize(2);
    tft.setCursor(15, 100); tft.print("FACTORY CALIBRATION");
    tft.setCursor(30, 130); tft.print("RESTORED TO MCU");
    delay(2000);
    currentPage = 1; lastPage = 0;
}

void drawHeader(const char* title) {
    int W = tft.width();
    tft.fillScreen(COLOR_BG);
    tft.fillRect(0, 0, W, 30, COLOR_GLASS_PANEL);
    tft.setCursor(5, 8);
    tft.setTextColor(COLOR_NEON_CYAN);
    tft.setTextSize(2);
    tft.print(title);
    tft.drawFastHLine(0, 30, W, COLOR_NEON_CYAN);
    
    // Page indicators
    for(int i=1; i<=5; i++) {
        uint16_t color = (i == currentPage) ? COLOR_NEON_CYAN : COLOR_GLASS_PANEL;
        tft.fillCircle(W - 80 + (i*12), 15, 3, color);
    }
}

void drawFooter() {
    int W = tft.width(); int H = tft.height();
    tft.fillRect(0, H - 30, W, 30, COLOR_GLASS_PANEL);
    tft.drawFastHLine(0, H - 30, W, COLOR_NEON_MAG);
    
    // Draw Prev/Next buttons
    tft.fillRect(5, H-25, 60, 20, 0x4208);
    tft.setCursor(15, H-22); tft.setTextColor(0xFFFF); tft.setTextSize(1); tft.print("< PREV");
    
    tft.fillRect(W-65, H-25, 60, 20, 0x4208);
    tft.setCursor(W-50, H-22); tft.setTextColor(0xFFFF); tft.setTextSize(1); tft.print("NEXT >");
}

void renderPage1() { drawHeader("1. HARDWARE"); drawFooter(); }
void renderPage2() { drawHeader("2. NETWORK"); drawFooter(); }
void renderPage3() { drawHeader("3. SERVER"); drawFooter(); }
void renderPage4() {
    drawHeader("4. COMMANDS"); drawFooter();
    tft.fillRoundRect(20, 50, 130, 40, 8, 0xF800); tft.setCursor(45, 62); tft.print("REBOOT");
    tft.fillRoundRect(170, 50, 130, 40, 8, 0x7800); tft.setCursor(185, 62); tft.print("SHUTDOWN");
    tft.fillRoundRect(20, 100, 130, 40, 8, COLOR_NEON_ORG); tft.setCursor(25, 112); tft.print("RESTART WEB");
    tft.fillRoundRect(170, 100, 130, 40, 8, COLOR_NEON_CYAN); tft.setCursor(175, 112); tft.print("CLEAR CACHE");
    tft.fillRoundRect(20, 150, 280, 40, 8, COLOR_NEON_MAG); tft.setCursor(100, 162); tft.print("UPDATE OS");
}
void renderPage5() {
    drawHeader("5. SETTINGS"); drawFooter();
    tft.fillRoundRect(40, 50, 240, 40, 8, 0x4208); tft.setCursor(90, 62); tft.print("CALIBRATE");
    tft.fillRoundRect(40, 100, 240, 40, 8, 0x4208); tft.setCursor(70, 112); tft.print("TOGGLE GRAPH");
    tft.fillRoundRect(40, 150, 240, 40, 8, 0x4208); tft.setCursor(80, 162); tft.print("REFRESH RATE");
}

void drawLabelValue(int x, int y, const char* label, String val, uint16_t valColor) {
    tft.setCursor(x, y); tft.setTextColor(0xC618); tft.print(label);
    tft.setCursor(x + 35, y); tft.setTextColor(valColor); tft.print(val);
}

void drawMiniBar(int x, int y, int w, int h, int pct, uint16_t color) {
    tft.fillRect(x, y, w, h, COLOR_OBSIDIAN);
    tft.drawRect(x, y, w, h, 0x4208);
    int fw = (w - 2) * constrain(pct, 0, 100) / 100;
    if(fw > 0) tft.fillRect(x + 1, y + 1, fw, h - 2, color);
}

void parsePayload(String payload) {
    if (payload.startsWith("P1|") && currentPage == 1) {
        // e.g. P1|C:10,20,30,40|FQ:1500/1800|TC:45.2|TG:46.0|TH:0x0|RM:8000,4000,2000|SW:0|DK:32,16|IO:1.2,0.5|UP:2d 4h|VL:0.85V
        tft.setTextSize(1);
        
        // --- CORES ---
        int cIdx = payload.indexOf("C:");
        if(cIdx > 0) {
            int cEnd = payload.indexOf("|", cIdx);
            String cData = payload.substring(cIdx + 2, cEnd);
            int c1 = cData.substring(0, cData.indexOf(',')).toInt();
            cData.remove(0, cData.indexOf(',') + 1);
            int c2 = cData.substring(0, cData.indexOf(',')).toInt();
            cData.remove(0, cData.indexOf(',') + 1);
            int c3 = cData.substring(0, cData.indexOf(',')).toInt();
            int c4 = cData.substring(cData.indexOf(',') + 1).toInt();
            
            tft.setCursor(10, 40); tft.setTextColor(0xFFFF); tft.print("CPU CORES");
            drawMiniBar(10, 52, 60,  8, c1, COLOR_NEON_CYAN); tft.setCursor(75, 52); tft.setTextColor(COLOR_NEON_CYAN); tft.fillRect(75, 52, 20, 8, COLOR_BG); tft.print(c1); tft.print("%");
            drawMiniBar(10, 64, 60,  8, c2, COLOR_NEON_CYAN); tft.setCursor(75, 64); tft.setTextColor(COLOR_NEON_CYAN); tft.fillRect(75, 64, 20, 8, COLOR_BG); tft.print(c2); tft.print("%");
            drawMiniBar(10, 76, 60,  8, c3, COLOR_NEON_CYAN); tft.setCursor(75, 76); tft.setTextColor(COLOR_NEON_CYAN); tft.fillRect(75, 76, 20, 8, COLOR_BG); tft.print(c3); tft.print("%");
            drawMiniBar(10, 88, 60,  8, c4, COLOR_NEON_CYAN); tft.setCursor(75, 88); tft.setTextColor(COLOR_NEON_CYAN); tft.fillRect(75, 88, 20, 8, COLOR_BG); tft.print(c4); tft.print("%");
        }

        // --- TEMPS ---
        int tcIdx = payload.indexOf("TC:");
        if(tcIdx > 0) {
            String tempCpu = payload.substring(tcIdx + 3, payload.indexOf("|", tcIdx));
            String tempGpu = payload.substring(payload.indexOf("TG:") + 3, payload.indexOf("|", payload.indexOf("TG:")));
            tft.fillRect(110, 40, 90, 30, COLOR_BG);
            drawLabelValue(110,  40, "CPU:", tempCpu + "C", COLOR_NEON_ORG);
            drawLabelValue(110,  55, "GPU:", tempGpu + "C", COLOR_NEON_MAG);
        }
        
        // --- RAM ---
        int rmIdx = payload.indexOf("RM:");
        if(rmIdx > 0) {
            String rmData = payload.substring(rmIdx + 3, payload.indexOf("|", rmIdx));
            int tot = rmData.substring(0, rmData.indexOf(',')).toInt();
            rmData.remove(0, rmData.indexOf(',') + 1);
            int usd = rmData.substring(0, rmData.indexOf(',')).toInt();
            int pct = (tot > 0) ? (usd * 100 / tot) : 0;
            
            tft.setCursor(10, 110); tft.setTextColor(0xFFFF); tft.print("MEMORY (MB)");
            drawMiniBar(10, 122, 100, 10, pct, COLOR_NEON_MAG);
            tft.fillRect(115, 122, 90, 10, COLOR_BG);
            tft.setCursor(115, 122); tft.setTextColor(COLOR_NEON_MAG);
            tft.print(usd); tft.print("/"); tft.print(tot);
        }
        
        // --- DISK ---
        int dkIdx = payload.indexOf("DK:");
        if(dkIdx > 0) {
            String dkData = payload.substring(dkIdx + 3, payload.indexOf("|", dkIdx));
            int tot = dkData.substring(0, dkData.indexOf(',')).toInt();
            int usd = dkData.substring(dkData.indexOf(',') + 1).toInt();
            int pct = (tot > 0) ? (usd * 100 / tot) : 0;
            
            tft.setCursor(10, 140); tft.setTextColor(0xFFFF); tft.print("ROOT DISK (GB)");
            drawMiniBar(10, 152, 100, 10, pct, 0x07E0);
            tft.fillRect(115, 152, 90, 10, COLOR_BG);
            tft.setCursor(115, 152); tft.setTextColor(0x07E0);
            tft.print(usd); tft.print("/"); tft.print(tot);
        }
        
        // --- UPTIME & VOLTS ---
        int upIdx = payload.indexOf("UP:");
        if(upIdx > 0) {
            String up = payload.substring(upIdx + 3, payload.indexOf("|", upIdx));
            String vl = payload.substring(payload.indexOf("VL:") + 3);
            tft.fillRect(110, 75, 120, 30, COLOR_BG);
            drawLabelValue(110,  75, "UP: ", up, 0xFFFF);
            drawLabelValue(110,  90, "PWR:", vl, 0xFFFF);
        }

    } 
    else if (payload.startsWith("P2|") && currentPage == 2) {
        tft.fillRect(0, 31, tft.width(), tft.height() - 62, COLOR_BG);
        tft.setTextSize(1); tft.setTextColor(0xFFFF);
        
        // P2|IP:{local_ip}|PUB:{public_ip}|PNG:{ping}|SSH:{ssh_users}|MAC:{mac}|BW:{rx_mb:.1f},{tx_mb:.1f}
        int y = 45;
        drawLabelValue(10, y, "LOCAL IP:", payload.substring(payload.indexOf("IP:") + 3, payload.indexOf("|", payload.indexOf("IP:"))), COLOR_NEON_CYAN); y += 20;
        drawLabelValue(10, y, "PUBLIC IP:", payload.substring(payload.indexOf("PUB:") + 4, payload.indexOf("|", payload.indexOf("PUB:"))), COLOR_NEON_MAG); y += 20;
        drawLabelValue(10, y, "PING 8.8.8.8:", payload.substring(payload.indexOf("PNG:") + 4, payload.indexOf("|", payload.indexOf("PNG:"))), COLOR_NEON_ORG); y += 20;
        drawLabelValue(10, y, "ACTIVE SSH:", payload.substring(payload.indexOf("SSH:") + 4, payload.indexOf("|", payload.indexOf("SSH:"))), 0x07E0); y += 20;
        
        String bw = payload.substring(payload.indexOf("BW:") + 3);
        drawLabelValue(10, y, "RX/TX (MB):", bw, 0xFFFF);
    }
    else if (payload.startsWith("P3|") && currentPage == 3) {
        tft.fillRect(0, 31, tft.width(), tft.height() - 62, COLOR_BG);
        tft.setTextSize(1); tft.setTextColor(0xFFFF);
        
        // P3|HTP:{http_code}|NGX:{nginx_status}|DCK:{docker_status}|SSL:{ssl_days}|VIS:{visitors}
        int y = 45;
        drawLabelValue(10, y, "HTTP STATUS:", payload.substring(payload.indexOf("HTP:") + 4, payload.indexOf("|", payload.indexOf("HTP:"))), COLOR_NEON_CYAN); y += 20;
        drawLabelValue(10, y, "NGINX STATE:", payload.substring(payload.indexOf("NGX:") + 4, payload.indexOf("|", payload.indexOf("NGX:"))), COLOR_NEON_MAG); y += 20;
        drawLabelValue(10, y, "DOCKER RUN:", payload.substring(payload.indexOf("DCK:") + 4, payload.indexOf("|", payload.indexOf("DCK:"))), COLOR_NEON_ORG); y += 20;
        drawLabelValue(10, y, "SSL EXPIRY:", payload.substring(payload.indexOf("SSL:") + 4, payload.indexOf("|", payload.indexOf("SSL:"))), 0x07E0); y += 20;
    }
}

void handleTouch(int px, int py) {
    int W = tft.width(); int H = tft.height();
    
    // Wake up
    if (screenSleeping) { screenSleeping = false; lastPage = 0; return; }
    
    // Navigation (Footer)
    if (py > H - 30) {
        if (px < 80) currentPage = max(1, currentPage - 1);
        if (px > W - 80) currentPage = min(5, currentPage + 1);
        return;
    }
    
    // Commands Page 4
    if (currentPage == 4) {
        if (py > 50 && py < 90) {
            if (px > 20 && px < 150) Serial.println("CMD:REBOOT");
            if (px > 170 && px < 300) Serial.println("CMD:SHUTDOWN");
        }
        if (py > 100 && py < 140) {
            if (px > 20 && px < 150) Serial.println("CMD:RESTART_WEB");
            if (px > 170 && px < 300) Serial.println("CMD:CLEAR_CACHE");
        }
        if (py > 150 && py < 190 && px > 20 && px < 300) Serial.println("CMD:APT_UPDATE");
        
        tft.fillRect(0, 31, tft.width(), 10, COLOR_BG);
        tft.setCursor(100, 35); tft.setTextColor(0xFFFF); tft.print("SENT!");
        delay(500); lastPage = 0; // force redraw
    }
    
    // Settings Page 5
    if (currentPage == 5) {
        if (px > 40 && px < 280) {
            if (py > 50 && py < 90) calibrateDisplay();
            if (py > 100 && py < 140) { graphMode = !graphMode; lastPage = 0; }
            if (py > 150 && py < 190) { refreshRate = (refreshRate==2000)?5000:2000; lastPage=0; }
        }
    }
}

void setup() {
    Serial.begin(115200);
    uint16_t ID = tft.readID();
    if (ID == 0xD3D3) ID = 0x9486;
    tft.begin(ID);
    tft.setRotation(1);
}

void loop() {
    // Screen Blanking (5 mins)
    if (millis() - lastTouch > 300000 && !screenSleeping) {
        tft.fillScreen(COLOR_BG);
        screenSleeping = true;
    }
    
    TSPoint p = ts.getPoint();
    pinMode(XM, OUTPUT); pinMode(YP, OUTPUT);
    
    if (p.z > MINPRESSURE && p.z < MAXPRESSURE) {
        if (millis() - lastUpdate > 300) {
            // Map the raw touch values explicitly to the screen dimensions in landscape mode.
            // X and Y are often swapped for landscape vs portrait.
            int py = map(p.x, TS_LEFT, TS_RT, 0, tft.height());
            int px = map(p.y, TS_TOP, TS_BOT, 0, tft.width());
            
            handleTouch(px, py);
            lastTouch = millis();
            lastUpdate = millis();
        }
    }
    
    if (!screenSleeping) {
        if (currentPage != lastPage) {
            if(currentPage == 1) renderPage1();
            else if(currentPage == 2) renderPage2();
            else if(currentPage == 3) renderPage3();
            else if(currentPage == 4) renderPage4();
            else if(currentPage == 5) renderPage5();
            
            Serial.print("REQ:PAGE"); Serial.println(currentPage);
            lastPage = currentPage;
        }
        
        if (Serial.available()) {
            String data = Serial.readStringUntil('\n');
            parsePayload(data);
        }
    }
}
